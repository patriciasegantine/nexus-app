#!/bin/sh
npx lint-staged
npm test

MAX_LINES=250
FAILED=0
FILES=$(git diff --cached --name-only)

while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    */components/ui/*) continue ;;
    *.ts|*.tsx) ;;
    *) continue ;;
  esac
  [ ! -f "$file" ] && continue

  lines=$(wc -l < "$file")
  if [ "$lines" -gt "$MAX_LINES" ]; then
    echo "❌ $file has $lines lines (max $MAX_LINES)"
    FAILED=1
  fi
done <<EOF
$FILES
EOF

if [ "$FAILED" -eq 1 ]; then
  echo "Commit blocked: split large files before committing."
  exit 1
fi
